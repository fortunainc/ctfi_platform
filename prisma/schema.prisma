// BehindTheProtocol Database Schema
// Anonymous operational intelligence network for clinical trial operators

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Anonymous User System with Enhanced Reputation
model User {
  id              String    @id @default(cuid())
  clerkId         String?   @unique
  handle          String    @unique // Auto-generated: Operator_XXXX, CRA_XXXX, SiteLead_XXXX
  reputationScore Int       @default(0)
  reputationTier  String    @default("Operator") // Operator, Experienced Operator, Senior Operator, Field Expert, Trusted Contributor
  badges          String[]  @default([]) // Trial Fixer, Protocol Navigator, Site Advocate, Enrollment Strategist
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  threads         Thread[]
  replies         Reply[]
  pollVotes       PollVote[]
  threadFollows   ThreadFollow[]
  playbooks       OperatorPlaybook[]
  confessions     TrialConfession[]
  careerDiscussions CareerDiscussion[]
}

// Assist Threads System
model Thread {
  id                String   @id @default(cuid())
  userId            String?
  title             String
  trialPhase        String   // Phase 1, Phase 2, Phase 3, Phase 4
  therapeuticArea   String   // Oncology, Rare Disease, Device, etc.
  siteCountRange    String   // 1-10, 11-50, 51-100, 100+
  issueCategory     String   // Enrollment, Protocol burden, Sponsor expectations, etc.
  description       String
  urgencyLevel      String   @default("Normal") // Normal, Needs Advice, Urgent, Critical
  additionalContext String?
  sameSituationCount Int     @default(0)
  signalType        String   @default("Assist") // Assist, Industry Signal, Career Survival
  
  // Relations
  user              User?    @relation(fields: [userId], references: [id])
  replies           Reply[]
  threadFollows     ThreadFollow[]
  patternSignals    PatternSignal[]
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Reply System
model Reply {
  id             String   @id @default(cuid())
  threadId       String
  userId         String?
  content        String
  helpfulVotes   Int      @default(0)
  isMostHelpful  Boolean  @default(false)
  isPinned       Boolean  @default(false) // For situation rooms
  
  // Relations
  thread         Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user           User?    @relation(fields: [userId], references: [id])
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Reality Check Polls System
model Poll {
  id               String    @id @default(cuid())
  question         String
  trialPhase       String
  therapeuticArea  String
  options          String[]  // Array of poll options
  duration         Int       @default(24) // 24, 48, or 72 hours
  expiresAt        DateTime
  
  // Relations
  pollVotes        PollVote[]
  
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// Poll Votes
model PollVote {
  id              String   @id @default(cuid())
  pollId          String
  userId          String?
  selectedOption  String
  
  // Relations
  poll            Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user            User?    @relation(fields: [userId], references: [id])
  
  createdAt       DateTime @default(now())
  
  @@unique([pollId, userId])
}

// Thread Follow System
model ThreadFollow {
  id        String   @id @default(cuid())
  threadId  String
  userId    String?
  
  // Relations
  thread    Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])
  
  createdAt DateTime @default(now())
  
  @@unique([threadId, userId])
}

// Industry Signals - Triggered by public events
model IndustrySignal {
  id              String   @id @default(cuid())
  title           String
  source          String   // FDA warning letters, EMA reports, trial terminations, etc.
  sourceUrl       String?
  eventDate       DateTime
  question        String   // Discussion prompt for operators
  therapeuticArea String?
  trialPhase      String?
  isActive        Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Operator Playbooks - Structured knowledge from high-value threads
model OperatorPlaybook {
  id                String   @id @default(cuid())
  title             String
  threadId          String?  // Source thread if converted from discussion
  userId            String?  // Creator
  situationDescription String
  warningSigns      String[] // Array of warning signs
  escalationSteps   String[] // Array of escalation steps
  escalationLanguage String  // Example language
  lessonsLearned    String
  therapeuticArea   String
  trialPhase        String?
  isPublished       Boolean  @default(true)
  
  // Relations
  user              User?    @relation(fields: [userId], references: [id])
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Trial Confessions - Anonymous stories
model TrialConfession {
  id              String   @id @default(cuid())
  userId          String?
  title           String
  content         String
  therapeuticArea String?
  trialPhase      String?
  isApproved      Boolean  @default(false) // Moderation approval
  
  // Relations
  user            User?    @relation(fields: [userId], references: [id])
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Career Survival Discussions
model CareerDiscussion {
  id              String   @id @default(cuid())
  userId          String?
  title           String
  content         String
  topic           String   // Pushing back on sponsors, Avoiding blame, CRO pressure, etc.
  helpfulVotes    Int      @default(0)
  
  // Relations
  user            User?    @relation(fields: [userId], references: [id])
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Case Drops - Weekly Anonymous Stories
model CaseDrop {
  id              String   @id @default(cuid())
  caseNumber      Int      @unique
  title           String
  content         String
  trialPhase      String
  outcome         String
  discussionLink  String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Trial Type Rooms (Situation Rooms)
model TrialTypeRoom {
  id               String    @id @default(cuid())
  name             String    @unique // Oncology Trials, Rare Disease Trials, Device Trials, etc.
  description      String
  slug             String    @unique
  participantCount Int       @default(0)
  lastActiveAt     DateTime  @default(now())
  isActive         Boolean   @default(true)
  closesAt         DateTime? // Auto-close after 30 days of inactivity
  
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// Pattern Recognition Engine (Backend AI Tags)
model PatternSignal {
  id             String   @id @default(cuid())
  threadId       String
  patternTag     String   // Protocol Burden, Enrollment Assumption Failure, etc.
  confidenceScore Float
  
  // Relations
  thread         Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  
  createdAt      DateTime @default(now())
  
  @@unique([threadId, patternTag])
}