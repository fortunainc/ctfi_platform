// BehindTheProtocol Database Schema
// Anonymous operational intelligence network for clinical trial operators

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Anonymous User System
model User {
  id              String    @id @default(cuid())
  clerkId         String?   @unique
  handle          String    @unique // Auto-generated: Operator_XXXX, CRA_XXXX, SiteLead_XXXX
  reputationScore Int       @default(0)
  reputationTier  String    @default("Operator") // Operator, Experienced Operator, Senior Operator, Field Expert, Trusted Contributor
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  threads         Thread[]
  replies         Reply[]
  pollVotes       PollVote[]
  threadFollows   ThreadFollow[]
}

// Assist Threads System
model Thread {
  id                String   @id @default(cuid())
  userId            String?
  title             String
  trialPhase        String   // Phase 1, Phase 2, Phase 3, Phase 4
  therapeuticArea   String   // Oncology, Rare Disease, Device, etc.
  siteCountRange    String   // 1-10, 11-50, 51-100, 100+
  issueCategory     String   // Enrollment, Protocol burden, Sponsor expectations, etc.
  description       String
  urgencyLevel      String   @default("Normal") // Normal, Needs Advice, Urgent, Critical
  additionalContext String?
  sameSituationCount Int     @default(0)
  
  // Relations
  user              User?    @relation(fields: [userId], references: [id])
  replies           Reply[]
  threadFollows     ThreadFollow[]
  patternSignals    PatternSignal[]
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Reply System
model Reply {
  id             String   @id @default(cuid())
  threadId       String
  userId         String?
  content        String
  helpfulVotes   Int      @default(0)
  isMostHelpful  Boolean  @default(false)
  
  // Relations
  thread         Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user           User?    @relation(fields: [userId], references: [id])
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Reality Check Polls System
model Poll {
  id               String    @id @default(cuid())
  question         String
  trialPhase       String
  therapeuticArea  String
  options          String[]  // Array of poll options
  duration         Int       @default(24) // 24, 48, or 72 hours
  expiresAt        DateTime
  
  // Relations
  pollVotes        PollVote[]
  
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// Poll Votes
model PollVote {
  id              String   @id @default(cuid())
  pollId          String
  userId          String?
  selectedOption  String
  
  // Relations
  poll            Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user            User?    @relation(fields: [userId], references: [id])
  
  createdAt       DateTime @default(now())
  
  @@unique([pollId, userId])
}

// Thread Follow System
model ThreadFollow {
  id        String   @id @default(cuid())
  threadId  String
  userId    String?
  
  // Relations
  thread    Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])
  
  createdAt DateTime @default(now())
  
  @@unique([threadId, userId])
}

// Case Drops - Weekly Anonymous Stories
model CaseDrop {
  id              String   @id @default(cuid())
  caseNumber      Int      @unique
  title           String
  content         String
  trialPhase      String
  outcome         String
  discussionLink  String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Trial Type Rooms
model TrialTypeRoom {
  id          String   @id @default(cuid())
  name        String   @unique // Oncology Trials, Rare Disease Trials, Device Trials, etc.
  description String
  slug        String   @unique
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Pattern Recognition Engine (Backend AI Tags)
model PatternSignal {
  id             String   @id @default(cuid())
  threadId       String
  patternTag     String   // Protocol Burden, Enrollment Assumption Failure, etc.
  confidenceScore Float
  
  // Relations
  thread         Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  
  createdAt      DateTime @default(now())
  
  @@unique([threadId, patternTag])
}